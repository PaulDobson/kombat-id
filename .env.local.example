# Copia este archivo a .env.local y completa con tus credenciales reales de Supabase
# Encuentra estas claves en: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=tu-clave-publica-aqui

# Service role key — encontrada en Project Settings > API
# NUNCA expongas esta clave al navegador ni la subas a control de versiones
# Esta clave omite Row Level Security y solo debe usarse en operaciones server-side
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# URL pública de tu aplicación — usada para generar QR codes y enlaces de verificación
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
